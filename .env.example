# Autonomous Cinematic Video Editor Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OPTIONAL API KEYS (only needed if using API mode instead of manual mode)
# =============================================================================

# Suno API key for music generation (optional - only for api mode)
# SUNO_API_KEY=your_suno_api_key_here

# ElevenLabs API key for voiceover generation (optional - only for api mode)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# =============================================================================
# RESOLVE SETTINGS
# =============================================================================

# Render preset name (must match a preset in DaVinci Resolve)
# RENDER_PRESET=H.264 Master

# Output directory for rendered files
# OUTPUT_DIR=C:/Users/YourName/Videos/Output

# LUT path for color grading (optional)
# LUT_PATH=C:/path/to/your/lut.cube

# Timeline settings
# TIMELINE_FPS=24
# TIMELINE_WIDTH=1920
# TIMELINE_HEIGHT=1080

# =============================================================================
# MODE SETTINGS
# =============================================================================

# Audio mode: "manual" (default) or "api"
# - manual: Generates prompt packs for you to use manually with Suno/ElevenLabs
# - api: Uses API integrations (requires API keys above)
# AUDIO_MODE=manual
