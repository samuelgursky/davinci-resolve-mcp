						[15]  = { 1, LH = { 10, 0.666666666666667 }, RH = { 50, 1 }, Flags = { Linear = true } },
						[105] = { 1, LH = { 75, 1 }, RH = { 110, 0.666666666666667 }, Flags = { Linear = true } },
						[119] = { 0, LH = { 115, 0.333333333333333 }, Flags = { Linear = true } }
					}
				},
				Text = TextPlus {
					Inputs = {
						GlobalOut = Input { Value = 500, },
